# Demo环境（Droplet/VPS + Managed PostgreSQL）
NODE_ENV=production
PORT=3001
JWT_SECRET=replace-with-a-32-char-random-string
JWT_EXPIRES_IN=7d

# 超级管理员账号
SUPER_ADMIN_ACCOUNT=your-admin-account-id
SUPER_ADMIN_PASSWORD=your-admin-password-here

# 登录验证码（仅限demo环境）
# LOGIN_UNIVERSAL_CODE=

# 演示环境默认打印邮箱验证码到后端日志；接入正式邮件时改为 resend 并填写密钥
EMAIL_OTP_PROVIDER=log
EMAIL_OTP_API_KEY=
EMAIL_OTP_FROM=康伴 <no-reply@example.com>
RESEND_API_KEY=
RESEND_FROM_EMAIL=康伴 <noreply@example.com>
EMAIL_OTP_REPLY_TO=
EMAIL_OTP_BRAND_NAME=康伴

# 对外地址（替换为你的公网IP或域名）
PUBLIC_API_URL=http://your-server-ip:3001
PUBLIC_MOBILE_URL=http://your-server-ip:5173
PUBLIC_ADMIN_URL=http://your-server-ip:5174
CORS_ORIGINS=http://your-server-ip:5173,http://your-server-ip:5174

# PostgreSQL
DATABASE_URL=
DB_HOST=your-db-host.example.com
DB_PORT=5432
DB_USERNAME=your_db_username
DB_PASSWORD=replace-with-db-password
DB_DATABASE=health_guardian
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
DB_SYNCHRONIZE=true
DB_LOGGING=false

# 容器内服务互联
AI_SERVICE_URL=http://ai-service:8000

# 演示账号（用于移动端邮箱登录）
SEED_DEMO_USER=true
DEMO_USER_PHONE=13800138000
DEMO_USER_EMAIL=demo@example.com
DEMO_USER_PASSWORD=change-this-password
DEMO_USER_NAME=演示用户
