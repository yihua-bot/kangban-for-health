# Server Configuration
NODE_ENV=development
PORT=3001

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_DATABASE=health_guardian
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false
DB_SYNCHRONIZE=true
DB_LOGGING=true

# JWT Configuration
# IMPORTANT: Change this secret in production!
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Login verification code (dev only, leave empty in production)
# LOGIN_UNIVERSAL_CODE=

# Email OTP Configuration
# Use `log` in local/dev to print codes in backend logs, or `resend` in production.
EMAIL_OTP_PROVIDER=log
EMAIL_OTP_API_KEY=
EMAIL_OTP_FROM=康伴 <no-reply@example.com>
RESEND_API_KEY=
RESEND_FROM_EMAIL=康伴 <noreply@example.com>
EMAIL_OTP_REPLY_TO=
EMAIL_OTP_BRAND_NAME=康伴

# AI Service
AI_SERVICE_URL=http://localhost:8000

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:4173

# Demo seed user (optional)
SEED_DEMO_USER=false
DEMO_USER_PHONE=13800138000
DEMO_USER_EMAIL=demo@example.com
DEMO_USER_PASSWORD=your-demo-password-here
DEMO_USER_NAME=演示用户
