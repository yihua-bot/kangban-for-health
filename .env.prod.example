NODE_ENV=production
PORT=3001

# Public API domain used by frontend
PUBLIC_API_URL=https://api.example.com

# Public frontend URLs
PUBLIC_MOBILE_URL=https://health.example.com
PUBLIC_ADMIN_URL=https://admin.example.com

# Frontend domains allowed to call API (comma-separated, no wildcard in prod)
CORS_ORIGINS=https://health.example.com,https://admin.example.com
STRICT_CORS=true

# PostgreSQL (recommended)
DATABASE_URL=
DB_HOST=your-db-host.example.com
DB_PORT=5432
DB_USERNAME=your_db_username
DB_PASSWORD=replace-with-db-password
DB_DATABASE=health_guardian
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
# Optional root CA content (single line with \n escapes), required only if your provider asks for custom CA.
DB_SSL_CA=

# Production defaults
DB_SYNCHRONIZE=false
DB_LOGGING=false
SEED_DEMO_USER=false

JWT_SECRET=replace-with-a-random-32-plus-char-secret
JWT_EXPIRES_IN=7d
# 留空，生产环境不要开启万能验证码
LOGIN_UNIVERSAL_CODE=

# 超级管理员账号
SUPER_ADMIN_ACCOUNT=your-admin-account-id
SUPER_ADMIN_PASSWORD=your-admin-password-here

AI_SERVICE_URL=http://ai-service:8000

# LLM 配置（AI 服务必需）
LLM_API_KEY=your-llm-api-key-here
LLM_BASE_URL=https://your-llm-provider.com/v1
LLM_MODEL=your-llm-model-name
LLM_VISION_MODEL=your-llm-vision-model-name
