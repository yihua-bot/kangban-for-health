# 服务配置
NODE_ENV=production
PORT=3001
AI_SERVICE_URL=http://ai-service:8000

# 对外访问地址（用于前端构建和CORS）
PUBLIC_API_URL=http://your-server-ip:3001
PUBLIC_MOBILE_URL=http://your-server-ip:5173
PUBLIC_ADMIN_URL=http://your-server-ip:5174
CORS_ORIGINS=http://your-server-ip:5173,http://your-server-ip:5174

# 数据库配置（PostgreSQL）
DATABASE_URL=
DB_HOST=your-db-host.example.com
DB_PORT=5432
DB_USERNAME=your_db_username
DB_PASSWORD=your-strong-password-here
DB_DATABASE=health_guardian
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
DB_SYNCHRONIZE=false
DB_LOGGING=false

# JWT配置（生产环境必须修改）
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
JWT_EXPIRES_IN=7d

# 超级管理员账号（必须设置，否则管理员登录不可用）
SUPER_ADMIN_ACCOUNT=your-admin-account-id
# 超级管理员密码（必须设置，否则管理员登录不可用）
SUPER_ADMIN_PASSWORD=your-admin-password-here

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# 登录验证码（仅限非生产环境使用，生产环境请留空）
# LOGIN_UNIVERSAL_CODE=

# 邮箱验证码服务（生产建议使用 resend）
EMAIL_OTP_PROVIDER=resend
EMAIL_OTP_API_KEY=re_xxxxxxxxxxxxxxxxx
EMAIL_OTP_FROM=康伴 <no-reply@yourdomain.com>
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
RESEND_API_ENDPOINT=https://api.resend.com/emails
RESEND_FROM_EMAIL=康伴 <noreply@yourdomain.com>
EMAIL_OTP_REPLY_TO=support@yourdomain.com
EMAIL_OTP_BRAND_NAME=康伴

# S3 兼容对象存储（不设置则存本地磁盘）
DO_SPACES_ENDPOINT=https://your-region.your-storage-provider.com
DO_SPACES_REGION=your-region
DO_SPACES_BUCKET=your-bucket-name
DO_SPACES_KEY=your-access-key
DO_SPACES_SECRET=your-secret-key
DO_SPACES_CDN_URL=https://your-bucket.your-storage-provider.com

# Sentry 错误监控（可选）
# SENTRY_DSN=https://xxx@sentry.io/xxx

# 可选：OpenAI API Key（用于增强AI分析）
# OPENAI_API_KEY=sk-your-openai-key

# 可选：演示环境自动创建测试用户（仅demo建议开启）
SEED_DEMO_USER=false
DEMO_USER_PHONE=13800138000
DEMO_USER_EMAIL=demo@example.com
DEMO_USER_PASSWORD=your-demo-password-here
DEMO_USER_NAME=演示用户
